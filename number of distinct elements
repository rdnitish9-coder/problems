class Solution {
    static int distinct(int arr[], int n) {
        // code here
        HashSet <Integer> st = new HashSet<>();
        for(int i =0;i<size(arr);i++)
        {
            st.add(arr[i]);
        }
        return st.size();
    }
    static int size(int[] arr)
    {
        int count = 0;
        for(int ele : arr) count ++;
        return count;
    }
}
